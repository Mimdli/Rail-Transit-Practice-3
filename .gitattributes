# Auto detect text files and perform LF normalization
* text=auto

# Python source files
*.py text diff=python

# Markdown files
*.md text

# Shell scripts
*.sh text eol=lf

# Batch scripts
*.bat text eol=crlf

# Binary files - keep as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
